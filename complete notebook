e.figsize'] = (12, 6)\n\n# Constants\nRANDOM_STATE = 42\nN_SPLITS = 5\nTARGET = 'energy_consumption'\n\nprint(\"All libraries imported successfully\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:23:28.534786Z","iopub.execute_input":"2026-02-10T20:23:28.535753Z","iopub.status.idle":"2026-02-10T20:23:28.543521Z","shell.execute_reply.started":"2026-02-10T20:23:28.535710Z","shell.execute_reply":"2026-02-10T20:23:28.542512Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Load data\ntrain = pd.read_csv('/kaggle/input/competitions/building-energy-consumption/train.csv')\ntest = pd.read_csv('/kaggle/input/competitions/building-energy-consumption/test.csv')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:23:38.285153Z","iopub.execute_input":"2026-02-10T20:23:38.285467Z","iopub.status.idle":"2026-02-10T20:23:38.410234Z","shell.execute_reply.started":"2026-02-10T20:23:38.285443Z","shell.execute_reply":"2026-02-10T20:23:38.409195Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 1.1 Exploratory Analysis (EDA)","metadata":{}},{"cell_type":"markdown","source":"**Content:**\n- Number of observations and variables\n- Types of data\n- Target Variable Analysis\n- Numerical Features\n- Categorial Features\n- Key Insights","metadata":{}},{"cell_type":"code","source":"train.head()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:21:17.747247Z","iopub.status.idle":"2026-02-10T20:21:17.747687Z","shell.execute_reply.started":"2026-02-10T20:21:17.747488Z","shell.execute_reply":"2026-02-10T20:21:17.747511Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Basic Structure\ntrain.shape\ntrain.columns","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:21:17.749517Z","iopub.status.idle":"2026-02-10T20:21:17.749941Z","shell.execute_reply.started":"2026-02-10T20:21:17.749780Z","shell.execute_reply":"2026-02-10T20:21:17.749799Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Understand the columns and Data types\ntrain.columns\ntrain.info()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":" ### Description of the Data\n\n**Structure of the Data**\n\nThe dataset contains **20,000 observations** and **18 variables**, including one target variable \"energy_consumption\" and one identifier \"id\". After excluding the identifier, 16 features are available for analysis.\n\n**Types of Data**\n\n- **Numerical** (Continuous/Discrete): Most features are numeric: floor_area, temp_outdoor, humidity, occupancy, wall_thickness, solar_irradiance, energy_consumption, etc.\n\nThese usually require scaling (normalization) or imputation if missing.\n\n- **Categorical (Nominal)**: heating_type (e.g., 'gas', 'electric', 'heatpump'). There is no intrinsic order here.\n\nNeeds One-Hot Encoding or Label Encoding.\n\n- **Categorical (Ordinal)**: insulation ('low', 'medium', 'high'). There is a clear ranking order.\n\nCan be mapped to numbers (1, 2, 3).\n\n- Metadata:\n\nid: A unique identifier for each row.\n\nRecommended to be dropped during training to prevent the model from memorizing IDs.\n\n**Quality of the data**\n\n- **Missing values** are present on key numerical featuresincluding temp_outdoor, humidity, and floor_area. Additionally, the target variable energy_consumption contains a small number of negative values,which is not meaningful and is recommended to be removed or transformed.\n","metadata":{}},{"cell_type":"code","source":"#Target Variable Analysis\ntarget_eda= \"energy_consumption\"\ntrain[target_eda].describe()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:24:08.516729Z","iopub.execute_input":"2026-02-10T20:24:08.517246Z","iopub.status.idle":"2026-02-10T20:24:08.537835Z","shell.execute_reply.started":"2026-02-10T20:24:08.517213Z","shell.execute_reply":"2026-02-10T20:24:08.536839Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Target Distribution\n\nplt.figure(figsize=(6,4))\nplt.hist(train[target_eda], bins=50)\nplt.xlabel(\"Energy consumption\")\nplt.ylabel(\"Frequency\")\nplt.title(\"Distribution of energy consumption\")\nplt.show()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Missing values\nmissing = train.isna().mean().sort_values(ascending=False)\nmissing.head(10)\nmissing[missing > 0].plot(kind=\"bar\", figsize=(12,4))\nplt.title(\"Proportion of missing values by column\")\nplt.show()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"num_features_eda = train.select_dtypes(include=[np.number])\n\nnum_features_eda.head()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Distribution of numerical features\n\nnum_features_eda_X = num_features_eda.drop(columns=[target_eda])\n\nnum_features_eda_X = num_features_eda_X.drop(columns=[\"id\"])\n\nnum_features_eda_X.columns\n\nnum_features_eda_X.hist(figsize=(15,10), bins=30)\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# General description of numerical features\nnum_features_eda_X.describe()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Correlation of numerial features with target\n\ncorr = train[num_features_eda_X.columns].corrwith(train[target_eda])\ncorr.sort_values(ascending=False)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Identify categorical variables\ncat_features_eda = train.select_dtypes(include=\"object\")\ncat_features_eda.columns","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# How many levels of categorical features?\nfor col in cat_features_eda.columns:\n    print(f\"\\n{col}\")\n    print(train[col].value_counts())","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Mean target by category\n\nfor col in cat_features_eda.columns:\n    display(\n        train.groupby(col)[\"energy_consumption\"]\n        .mean()\n        .sort_values(ascending=False)\n    )","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Categorical Impact\n\nfor col in cat_features_eda.columns:\n    plt.figure(figsize=(6,3))\n    sns.boxplot(x=col, y=\"energy_consumption\", data=train)\n    plt.title(f\"Energy consumption by {col}\")\n    plt.xticks(rotation=30)\n    plt.show()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Category Frequency\nfor col in cat_features_eda.columns:\n    display(train[col].value_counts(normalize=True))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### Key Insights EDA\n___\n**Key Insights – Numerical Features**\n\n\n- **energy_consumption** shows an approximately bell-shaped distribution with moderate spread and a small number of extreme values.\n- Weather-related variables **(temp_outdoor, humidity)** display the strongest linear relationships with energy consumption.\n- **floor_area** is positively correlated with energy usage, indicating that larger buildings tend to consume more energy.\n- **occupancy** shows a positive association with energy consumption and takes discrete values between 1 and 5.\n- Several numerical features exhibit weak linear correlation with the target, suggesting potential non-linear effects or limited predictive contribution.\n\n\n**Key Insights – Categorical Features**\n\n\n- Buildings with higher **insulation** quality tend to exhibit lower average energy consumption.\n- **Heating type** influences consumption, with heat pumps showing lower average usage compared to gas and electric systems.\n- The distributions of **insulation** and **heating_type** are reasonably balanced, with no extreme class imbalance.","metadata":{}},{"cell_type":"markdown","source":"### 1.2 Load Data and Clip Negative Values\n\n**Explanation:**\n- We load training and test datasets\n- Energy consumption cannot be negative, so we clip values to 0\n- This is a **regression problem** where we predict continuous values (kWh)","metadata":{}},{"cell_type":"code","source":"\n# Handle impossible values (negative energy consumption)\ntrain[TARGET] = train[TARGET].clip(lower=0)\n\nprint(f\"Training set shape: {train.shape}\")\nprint(f\"Test set shape: {test.shape}\")\nprint(f\"\\nTarget variable statistics:\")\nprint(train[TARGET].describe())","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 1.3 NMAR Analysis (Not Missing At Random)\n\nMissing data mechanisms were analyzed with a particular focus on Not Missing At Random (NMAR) patterns. NMAR occurs when the probability of a value being missing depends on the unobserved value itself. In the context of building energy consumption, this situation can arise, for example, when temperature sensors fail during extreme weather conditions, meaning that missing temperature values are not random but linked to unusually high or low temperatures.\n\nUnderstanding NMAR behavior is important because missingness may carry additional information about energy usage. If buildings with missing temperature data exhibit systematically different energy consumption levels compared to buildings with observed temperature values, the missingness itself becomes informative. Ignoring such patterns may lead to biased predictions.\n\nTo investigate potential NMAR effects, we compared the mean energy consumption for observations where a given feature was missing with the mean energy consumption where the same feature was present. A substantial difference between these two groups indicates that the missingness is likely related to the target variable rather than occurring at random.","metadata":{}},{"cell_type":"code","source":"# Identify columns with missing values\nmiss = train.isnull().sum().to_frame(name='train_missing')\nmissing_cols = miss[miss[\"train_missing\"] > 0].index.tolist()\n\n# Analyze NMAR: Does missingness correlate with target?\nnmar_report = []\nfor c in missing_cols:\n    m = train[c].isna()\n    if m.any() and (~m).any():\n        y_missing = train.loc[m, TARGET].mean()\n        y_present = train.loc[~m, TARGET].mean()\n        diff = y_missing - y_present\n        nmar_report.append((c, m.mean(), y_missing, y_present, diff))\n\nnmar_df = pd.DataFrame(\n    nmar_report,\n    columns=[\"col\", \"missing_rate\", \"mean_y_missing\", \"mean_y_present\", \"diff_missing_minus_present\"]\n).sort_values(\"diff_missing_minus_present\", key=np.abs, ascending=False)\n\nprint(\"=\"*80)\nprint(\"NMAR ANALYSIS: Impact of Missing Data on Energy Consumption\")\nprint(\"=\"*80)\nprint(nmar_df.to_string(index=False))\nprint(\"Interpretation:\")\nprint(\"Buildings with missing values consume MORE energy\")\n\nnmar_cols = nmar_df['col'].tolist()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:24:20.231353Z","iopub.execute_input":"2026-02-10T20:24:20.231860Z","iopub.status.idle":"2026-02-10T20:24:20.262583Z","shell.execute_reply.started":"2026-02-10T20:24:20.231831Z","shell.execute_reply":"2026-02-10T20:24:20.261838Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 1.4 Feature Engineering\n\nFeature engineering was guided by knowledge from building physics and energy systems, with the goal of capturing non-linear effects and meaningful interactions between variables. Special attention was given to ensuring that engineered features remain interpretable and physically plausible.\n\n1. **Missingness Indicators** - Binary flags for NMAR patterns\n2. **Weather Features:**\n   - temp_sq: Quadratic temperature (captures non-linear heating/cooling)\n   - HDD: Heating Degree Days = max(18°C - temp, 0)\n   - CDD: Cooling Degree Days = max(temp - 18°C, 0)\n   - wind_x_temp: Wind amplifies temperature effects\n\n3. **Insulation Score** - Convert categorical (low/med/high) to ordinal (0/1/2)\n\n4. **Interaction Features** (Physics-based):\n   - temp_x_insulation`: Insulation matters more in extreme temps\n   - temp_x_wall: Wall thickness provides temperature buffer\n   - solar_x_window_age: Old windows lose solar heat gain\n   - wall_per_area: Thermal mass per unit area\n   - occupancy_density: People per square meter\n\n5. **Building Age** - Older buildings typically less efficient","metadata":{}},{"cell_type":"code","source":"def build_advanced_features(df):\n    \"\"\"\n    Create engineered features from raw building data.\n    \n    Returns:\n        DataFrame with original + engineered features\n    \"\"\"\n    out = df.copy()\n    eps = 1e-6  # Small constant to avoid division by zero\n\n    # 1. NMAR Indicators\n    for col in nmar_cols:\n        if col in out.columns:\n            out[f'{col}_is_missing'] = out[col].isna().astype(int)\n\n    # 2. Weather Features\n    out['temp_sq'] = out[\"temp_outdoor\"]** 2\n    out['HDD'] = (18 - out['temp_outdoor']).clip(lower=0)\n    out['CDD'] = (out['temp_outdoor'] - 18).clip(lower=0)\n    out['wind_x_temp'] = out['wind_exposure'] * out['temp_outdoor']\n\n    # 3. Ordinal Encoding for insulation\n    insulation_map = {'low': 0, 'medium': 1, 'high': 2}\n    out['insulation_score'] = out['insulation'].map(insulation_map).fillna(1)\n\n    # 4. Physics-Based Interactions\n    out['temp_x_insulation'] = out['temp_outdoor'] * out['insulation_score']\n    out['temp_x_wall'] = out['temp_outdoor'] * out['wall_thickness']\n    out['solar_x_window_age'] = out['solar_irradiance'] * out['window_age']\n    out['wall_per_area'] = out['wall_thickness'] / (out['floor_area'] + eps)\n    out['occupancy_density'] = out['occupancy'] / (out['floor_area'] + 1.0)\n\n    # 5. Building Age (2026 as reference year)\n    out['building_age'] = 2026 - out['construction_year']\n\n    return out\n\nprint(\"Feature engineering function defined\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:24:29.292399Z","iopub.execute_input":"2026-02-10T20:24:29.292671Z","iopub.status.idle":"2026-02-10T20:24:29.302114Z","shell.execute_reply.started":"2026-02-10T20:24:29.292650Z","shell.execute_reply":"2026-02-10T20:24:29.301176Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Apply feature engineering\nX_train = build_advanced_features(train.drop(columns=[TARGET]))\ny_train = train[TARGET].values\nX_test = build_advanced_features(test)\n\nprint(f\"Features after engineering: {X_train.shape[1]}\")\nprint(f\"Training samples: {len(X_train)}\")\nprint(f\"Test samples: {len(X_test)}\")\n\n# Identify numeric columns\nnum_cols = X_train.select_dtypes(include=[np.number]).columns\nprint(f\"\\nNumeric columns: {len(num_cols)}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:24:32.753935Z","iopub.execute_input":"2026-02-10T20:24:32.754310Z","iopub.status.idle":"2026-02-10T20:24:32.801802Z","shell.execute_reply.started":"2026-02-10T20:24:32.754282Z","shell.execute_reply":"2026-02-10T20:24:32.801078Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"---\n## Part 2: Hyperparameter Tuning with Nested Cross-Validation\n---\n\nIn this phase of the experiment, we implemented **Nested Cross-Validation (Nested CV)** to robustly tune the hyperparameters of our models. This approach was chosen to ensure that our performance estimates are unbiased and to prevent data leakage.\n\n#### 2.1 **Methodology:**\n\nOur Nested CV structure consists of two loops:\n\n**Outer Loop (5 Folds):** responsible for evaluating the model's generalization performance.\n\n**Inner Loop (2 Folds):** responsible for selecting the optimal hyperparameters using only the training data available within the current outer fold.\n\nBy isolating the hyperparameter search within the inner loop, we guarantee that the test data (the validation fold of the outer loop) is never used to select the best parameters. This provides a more realistic estimate of how the model will perform on completely unseen data.\n\n\n#### 2.2 Tuning Procedure & \"Consensus\" Parameters\n\nFor each model (CatBoost, XGBoost, Ridge, and Random Forest), we performed a grid search within each outer fold. This resulted in 5 sets of \"best\" parameters-one for each fold.\n\nTo determine the final configuration for our production model, we aggregated these results by taking the **mode** (the most frequently occurring value) for each hyperparameter. This \"consensus\" set of parameters represents the configuration that was most stable and effective across different subsets of the data.\n\n#### 2.3 Search Space\n\nWe targeted the specific hyperparameters that control model complexity and overfitting for each algorithm:\n\n- **CatBoost:** Focused on tree structure (depth), optimization speed (learning_rate, iterations), and regularization (l2_leaf_reg).  \n- **XGBoost:** Tuned similar tree parameters (max_depth, n_estimators) alongside stochastic features (subsample, colsample_bytree) to add randomness and robustness.  \n- **Ridge Regression:** Optimized the 'alpha' parameter, which controls the strength of L2 regularization to handle multicollinearity.  \n- **Random Forest:** Adjusted tree quantity (n_estimators) and pruning parameters (max_depth, min_samples_leaf) to balance bias and variance.\n","metadata":{}},{"cell_type":"code","source":"# Hyperparameter grids (kept small for runtime)\nparam_grid_cb = {\n    \"depth\": [4, 6],\n    \"learning_rate\": [0.03, 0.06],\n    \"l2_leaf_reg\": [3, 7],\n    \"iterations\": [600, 900]\n}\n\nparam_grid_xgb = {\n    \"max_depth\": [4, 6],\n    \"learning_rate\": [0.03, 0.05],\n    \"subsample\": [0.8, 1.0],\n    \"colsample_bytree\": [0.8, 1.0],\n    \"n_estimators\": [400, 800]\n}\n\nparam_grid_ridge = {\n    \"ridge__alpha\": [0.5, 2.0, 10.0]\n}\n\nparam_grid_rf = {\n    \"n_estimators\": [200, 500],\n    \"max_depth\": [8, 12],\n    \"min_samples_leaf\": [1, 3]\n}\n\ndef _mode_params(list_of_dicts):\n    \"\"\"\n    Aggregate best params across folds by taking mode of each hyperparameter.\n    This gives us a single 'consensus' parameter set.\n    \"\"\"\n    keys = set().union(*list_of_dicts)\n    out = {}\n    for k in keys:\n        vals = [d.get(k) for d in list_of_dicts if k in d]\n        out[k] = Counter(vals).most_common(1)[0][0]\n    return out\n\ndef _n_candidates(grid):\n    \"\"\"Calculate total number of hyperparameter combinations.\"\"\"\n    n = 1\n    for v in grid.values():\n        n *= len(v)\n    return n\n\nprint(\"=\"*80)\nprint(\"HYPERPARAMETER TUNING SETUP\")\nprint(\"=\"*80)\nprint(f\"Candidate counts:\")\nprint(f\"  CatBoost: {_n_candidates(param_grid_cb)} combinations\")\nprint(f\"  XGBoost: {_n_candidates(param_grid_xgb)} combinations\")\nprint(f\"  Ridge: {_n_candidates(param_grid_ridge)} combinations\")\nprint(f\"  RandomForest: {_n_candidates(param_grid_rf)} combinations\")\nprint(f\"\\nCross-validation strategy:\")\nprint(f\"  Outer folds: {N_SPLITS} (for performance evaluation)\")\nprint(f\"  Inner folds: 2 (for hyperparameter tuning)\")\nprint(\"=\"*80)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:24:50.543355Z","iopub.execute_input":"2026-02-10T20:24:50.544407Z","iopub.status.idle":"2026-02-10T20:24:50.554610Z","shell.execute_reply.started":"2026-02-10T20:24:50.544364Z","shell.execute_reply":"2026-02-10T20:24:50.553659Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Storage for best params from each outer fold\nbest_params_cb_folds = []\nbest_params_xgb_folds = []\nbest_params_ridge_folds = []\nbest_params_rf_folds = []\n\n# Inner CV for grid search\ninner_cv = KFold(n_splits=2, shuffle=True, random_state=RANDOM_STATE)\nkf_tune = KFold(n_splits=N_SPLITS, shuffle=True, random_state=RANDOM_STATE)\n\nprint(\"\\n Starting Nested Cross-Validation for Hyperparameter Tuning...\\n\")\ntune_start = time.time()\n\nfor fold, (tr_idx, va_idx) in enumerate(kf_tune.split(X_train), 1):\n    fold_start = time.time()\n    print(f\"{'='*60}\")\n    print(f\"OUTER FOLD {fold}/{N_SPLITS}\")\n    print(f\"{'='*60}\")\n\n    # Split data (NO leakage - imputation and encoding done per fold)\n    X_tr, X_va = X_train.iloc[tr_idx].copy(), X_train.iloc[va_idx].copy()\n    y_tr, y_va = y_train[tr_idx], y_train[va_idx]\n\n    # Fit imputer on training fold ONLY\n    imputer = SimpleImputer(strategy='median')\n    X_tr[num_cols] = imputer.fit_transform(X_tr[num_cols])\n    X_va[num_cols] = imputer.transform(X_va[num_cols])\n\n    # One-hot encoding on training fold ONLY\n    X_tr = pd.get_dummies(X_tr, columns=['heating_type'], prefix='heat')\n    X_va = pd.get_dummies(X_va, columns=['heating_type'], prefix='heat')\n    X_va = X_va.reindex(columns=X_tr.columns, fill_value=0)\n\n    # Prepare numeric features\n    X_tr_numeric = X_tr.drop(columns=['insulation', 'id'], errors='ignore')\n\n    # --- CatBoost Grid Search ---\n    print(f\"\\n[1/4] Tuning CatBoost...\")\n    cb_base = CatBoostRegressor(\n        verbose=0,\n        random_seed=RANDOM_STATE,\n        loss_function=\"RMSE\"\n    )\n    gs_cb = GridSearchCV(\n        estimator=cb_base,\n        param_grid=param_grid_cb,\n        scoring=\"neg_root_mean_squared_error\",\n        cv=inner_cv,\n        n_jobs=-1\n    )\n    gs_cb.fit(X_tr_numeric, y_tr)\n    best_params_cb_folds.append(gs_cb.best_params_)\n    print(f\"   Best params: {gs_cb.best_params_}\")\n    print(f\"   Best CV score: {-gs_cb.best_score_:.4f} RMSE\")\n\n    # --- Ridge Grid Search ---\n    print(f\"\\n[2/4] Tuning Ridge...\")\n    ridge_base = Pipeline([\n        ('scaler', StandardScaler()),\n        ('ridge', Ridge())\n    ])\n    gs_ridge = GridSearchCV(\n        estimator=ridge_base,\n        param_grid=param_grid_ridge,\n        scoring=\"neg_root_mean_squared_error\",\n        cv=inner_cv,\n        n_jobs=-1\n    )\n    gs_ridge.fit(X_tr_numeric, y_tr)\n    best_params_ridge_folds.append(gs_ridge.best_params_)\n    print(f\"   Best params: {gs_ridge.best_params_}\")\n    print(f\"   Best CV score: {-gs_ridge.best_score_:.4f} RMSE\")\n\n    # --- Random Forest Grid Search ---\n    print(f\"\\n[3/4] Tuning Random Forest...\")\n    rf_base = RandomForestRegressor(random_state=RANDOM_STATE, n_jobs=-1)\n    gs_rf = GridSearchCV(\n        estimator=rf_base,\n        param_grid=param_grid_rf,\n        scoring=\"neg_root_mean_squared_error\",\n        cv=inner_cv,\n        n_jobs=-1\n    )\n    gs_rf.fit(X_tr_numeric, y_tr)\n    best_params_rf_folds.append(gs_rf.best_params_)\n    print(f\"   Best params: {gs_rf.best_params_}\")\n    print(f\"   Best CV score: {-gs_rf.best_score_:.4f} RMSE\")\n\n    # --- XGBoost Grid Search ---\n    print(f\"\\n[4/4] Tuning XGBoost...\")\n    xgb_base = XGBRegressor(random_state=RANDOM_STATE, eval_metric=\"rmse\")\n    gs_xgb = GridSearchCV(\n        estimator=xgb_base,\n        param_grid=param_grid_xgb,\n        scoring=\"neg_root_mean_squared_error\",\n        cv=inner_cv,\n        n_jobs=-1\n    )\n    gs_xgb.fit(X_tr_numeric, y_tr)\n    best_params_xgb_folds.append(gs_xgb.best_params_)\n    print(f\"   Best params: {gs_xgb.best_params_}\")\n    print(f\"   Best CV score: {-gs_xgb.best_score_:.4f} RMSE\")\n\n    fold_time = time.time() - fold_start\n    print(f\"\\n⏱️  Fold {fold} completed in {fold_time:.1f}s\\n\")\n\ntotal_tune_time = time.time() - tune_start\nprint(f\"\\n{'='*60}\")\nprint(f\"✓ Hyperparameter tuning completed in {total_tune_time:.1f}s\")\nprint(f\"{'='*60}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Aggregate best parameters across folds (take mode)\nbest_params_cb = _mode_params(best_params_cb_folds)\nbest_params_xgb = _mode_params(best_params_xgb_folds)\nbest_params_ridge = _mode_params(best_params_ridge_folds)\nbest_params_rf = _mode_params(best_params_rf_folds)\n\nprint(\"\\n\" + \"=\"*80)\nprint(\"FINAL HYPERPARAMETERS (Mode across folds)\")\nprint(\"=\"*80)\nprint(f\"\\nCatBoost:\")\nfor k, v in best_params_cb.items():\n    print(f\"  {k}: {v}\")\n\nprint(f\"\\nXGBoost:\")\nfor k, v in best_params_xgb.items():\n    print(f\"  {k}: {v}\")\n\nprint(f\"\\nRidge:\")\nfor k, v in best_params_ridge.items():\n    print(f\"  {k}: {v}\")\n\nprint(f\"\\nRandom Forest:\")\nfor k, v in best_params_rf.items():\n    print(f\"  {k}: {v}\")\n\nprint(\"\\n\" + \"=\"*80)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#Lock-in best parameters\n\nbest_params_cb = {\n    \"iterations\": 600,\n    \"depth\": 4,\n    \"learning_rate\": 0.03,\n    \"l2_leaf_reg\": 3,\n}\n \nbest_params_xgb = {\n    \"subsample\": 0.8,\n    \"learning_rate\": 0.03,\n    \"max_depth\": 4,\n    \"n_estimators\": 400,\n    \"colsample_bytree\": 0.8,\n}\n \nbest_params_ridge = {\n    \"alpha\": 2.0,\n}\n \nbest_params_rf = {\n    \"max_depth\": 12,\n    \"min_samples_leaf\": 3,\n    \"n_estimators\": 500,\n}","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:26:57.725959Z","iopub.execute_input":"2026-02-10T20:26:57.726932Z","iopub.status.idle":"2026-02-10T20:26:57.731814Z","shell.execute_reply.started":"2026-02-10T20:26:57.726898Z","shell.execute_reply":"2026-02-10T20:26:57.731042Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"---\n## Part 3: Final Model Training with Optimal Hyperparameters\n---\n\nWith the optimal hyperparameters identified via Nested Cross-Validation, we proceeded to the final training phase. The objective here was not just to train a single best model, but to construct a robust Ensemble composed of diverse algorithms.\n\n### Algorithm Selection & Diversity\n\nWe selected four distinct algorithms to maximize the diversity of our ensemble. The principle of ensembling relies on \"error independence\" – if models make different kinds of mistakes, averaging them cancels out the errors.\n\n**Gradient Boosting (CatBoost & XGBoost):** Chosen for their state-of-the-art performance on tabular data. CatBoost specifically excels at handling the categorical features (like heating_type) and missing data without extensive preprocessing.\n\n**Bagging (Random Forest):** Included for its robustness. Unlike boosting, which reduces bias, Random Forest reduces variance and is less likely to overfit to outliers in the noise.\n\n**Linear Baseline (Ridge Regression):** Included to capture simple linear trends. If the relationship between a feature (like HDD) and energy is linear, Ridge will capture it more smoothly than a tree-based model, acting as a stabilizer for the ensemble.\n\n**Out-of-Fold (OOF) Predictions:**\n- Each sample gets a prediction from a model that never saw it during training  \n- Gives unbiased estimate of generalization performance  \n- Used for meta-learning (blending)\n\n**Why ensemble?**\nThe ensemble reduces the overall variance of predictions and smooths out the idiosyncrasies of any single algorithm. For example, if XGBoost overreacts to a specific outlier but Ridge ignores it, the weighted average will find a middle ground closer to the truth.\n\n### 3.1 Training the Models\n","metadata":{}},{"cell_type":"code","source":"# Prepare for final training\nkf_final = KFold(n_splits=N_SPLITS, shuffle=True, random_state=RANDOM_STATE)\n\n# Initialize OOF and test prediction arrays\noof_cb = np.zeros(len(X_train))\noof_ridge = np.zeros(len(X_train))\noof_rf = np.zeros(len(X_train))\noof_xgb = np.zeros(len(X_train))\n\ntest_cb = np.zeros(len(X_test))\ntest_ridge = np.zeros(len(X_test))\ntest_rf = np.zeros(len(X_test))\ntest_xgb = np.zeros(len(X_test))\n\n# Store models for XAI analysis later\nmodels_cb = []\nmodels_xgb = []\nmodels_ridge = []\nmodels_rf = []\n\nprint(\"\\n Training final models with optimal hyperparameters...\\n\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:27:16.771909Z","iopub.execute_input":"2026-02-10T20:27:16.772742Z","iopub.status.idle":"2026-02-10T20:27:16.781370Z","shell.execute_reply.started":"2026-02-10T20:27:16.772709Z","shell.execute_reply":"2026-02-10T20:27:16.780385Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"for fold, (tr_idx, va_idx) in enumerate(kf_final.split(X_train), 1):\n    print(f\"Training fold {fold}/{N_SPLITS}...\")\n\n    # Split data\n    X_tr, X_va = X_train.iloc[tr_idx].copy(), X_train.iloc[va_idx].copy()\n    y_tr, y_va = y_train[tr_idx], y_train[va_idx]\n\n    # Imputation (fit on train, transform both)\n    imputer = SimpleImputer(strategy='median')\n    X_tr[num_cols] = imputer.fit_transform(X_tr[num_cols])\n    X_va[num_cols] = imputer.transform(X_va[num_cols])\n\n    # One-hot encoding\n    X_tr = pd.get_dummies(X_tr, columns=['heating_type'], prefix='heat')\n    X_va = pd.get_dummies(X_va, columns=['heating_type'], prefix='heat')\n    X_va = X_va.reindex(columns=X_tr.columns, fill_value=0)\n\n    # Prepare final numeric features\n    X_tr_numeric = X_tr.drop(columns=['insulation', 'id'], errors='ignore')\n    X_va_numeric = X_va.drop(columns=['insulation', 'id'], errors='ignore')\n\n    # Process test data (same transformations)\n    X_test_fold = X_test.copy()\n    X_test_fold[num_cols] = imputer.transform(X_test_fold[num_cols])\n    X_test_fold = pd.get_dummies(X_test_fold, columns=['heating_type'], prefix='heat')\n    X_test_fold = X_test_fold.reindex(columns=X_tr.columns, fill_value=0)\n    X_test_numeric = X_test_fold.drop(columns=['insulation', 'id'], errors='ignore')\n\n    # --- Model 1: CatBoost ---\n    model_cb = CatBoostRegressor(\n        **best_params_cb,\n        verbose=0,\n        random_seed=RANDOM_STATE,\n        loss_function=\"RMSE\"\n    )\n    model_cb.fit(X_tr_numeric, y_tr, eval_set=(X_va_numeric, y_va), early_stopping_rounds=50)\n    oof_cb[va_idx] = model_cb.predict(X_va_numeric)\n    test_cb += model_cb.predict(X_test_numeric) / N_SPLITS\n    models_cb.append(model_cb)\n\n    # --- Model 2: Ridge ---\n    model_ridge = Pipeline([\n        ('scaler', StandardScaler()),\n        ('ridge', Ridge(alpha=best_params_ridge.get(\"ridge__alpha\", 2.0)))\n    ])\n    model_ridge.fit(X_tr_numeric, y_tr)\n    oof_ridge[va_idx] = model_ridge.predict(X_va_numeric)\n    test_ridge += model_ridge.predict(X_test_numeric) / N_SPLITS\n    models_ridge.append(model_ridge)\n\n    # --- Model 3: Random Forest ---\n    model_rf = RandomForestRegressor(\n        **best_params_rf,\n        random_state=RANDOM_STATE,\n        n_jobs=-1\n    )\n    model_rf.fit(X_tr_numeric, y_tr)\n    oof_rf[va_idx] = model_rf.predict(X_va_numeric)\n    test_rf += model_rf.predict(X_test_numeric) / N_SPLITS\n    models_rf.append(model_rf)\n\n    # --- Model 4: XGBoost ---\n    model_xgb = XGBRegressor(\n        **best_params_xgb,\n        random_state=RANDOM_STATE,\n        early_stopping_rounds=50,\n        eval_metric=\"rmse\"\n    )\n    model_xgb.fit(X_tr_numeric, y_tr, eval_set=[(X_va_numeric, y_va)], verbose=False)\n    oof_xgb[va_idx] = model_xgb.predict(X_va_numeric)\n    test_xgb += model_xgb.predict(X_test_numeric) / N_SPLITS\n    models_xgb.append(model_xgb)\n\nprint(\"\\n All models trained successfully!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:27:21.618955Z","iopub.execute_input":"2026-02-10T20:27:21.619355Z","iopub.status.idle":"2026-02-10T20:33:15.471750Z","shell.execute_reply.started":"2026-02-10T20:27:21.619329Z","shell.execute_reply":"2026-02-10T20:33:15.471088Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 3.2 Model Performance Evaluation\n\n**Metric: RMSE (Root Mean Squared Error)**\n- Measures average prediction error in kWh\n- Lower is better\n- Same units as target (interpretable)\n- Penalizes large errors more than small errors","metadata":{}},{"cell_type":"code","source":"def rmse_score(y_true, y_pred):\n    return np.sqrt(mean_squared_error(y_true, y_pred))\n\n# Manual ensemble weights (based on performance)\nw_cb = 0.40\nw_xgb = 0.30\nw_ridge = 0.20\nw_rf = 0.10\n\n# Calculate weighted ensemble\noof_ensemble = (w_cb * oof_cb) + (w_xgb * oof_xgb) + (w_ridge * oof_ridge) + (w_rf * oof_rf)\ntest_preds = (w_cb * test_cb) + (w_xgb * test_xgb) + (w_ridge * test_ridge) + (w_rf * test_rf)\n\nprint(\"=\"*80)\nprint(\"MODEL PERFORMANCE (Out-of-Fold RMSE)\")\nprint(\"=\"*80)\nprint(f\"CatBoost:       {rmse_score(y_train, oof_cb):.4f} kWh  (weight: {w_cb})\")\nprint(f\"XGBoost:        {rmse_score(y_train, oof_xgb):.4f} kWh  (weight: {w_xgb})\")\nprint(f\"Ridge:          {rmse_score(y_train, oof_ridge):.4f} kWh  (weight: {w_ridge})\")\nprint(f\"Random Forest:  {rmse_score(y_train, oof_rf):.4f} kWh  (weight: {w_rf})\")\nprint(\"=\"*80)\nprint(f\"ENSEMBLE:       {rmse_score(y_train, oof_ensemble):.4f} kWh\")\nprint(\"=\"*80)\nprint(f\"\\n Interpretation:\")\nprint(f\"   On average, our predictions are off by ~{rmse_score(y_train, oof_ensemble):.2f} kWh\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:33:22.157098Z","iopub.execute_input":"2026-02-10T20:33:22.157410Z","iopub.status.idle":"2026-02-10T20:33:22.172680Z","shell.execute_reply.started":"2026-02-10T20:33:22.157386Z","shell.execute_reply":"2026-02-10T20:33:22.171476Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"#binned residual plot of the models\n#Conditioned on the true consumption level, do models systematically over- or under-predict?\ny_true = train[TARGET].values\n\npreds = {\n    \"CatBoost\": oof_cb,\n    \"XGBoost\": oof_xgb,\n    \"Ridge\": oof_ridge,\n    \"Random Forest\": oof_rf\n}\n\n# Bin by actual values\ndf_base = pd.DataFrame({\"actual\": y_true})\ndf_base[\"bin\"] = pd.qcut(df_base[\"actual\"], q=6, duplicates=\"drop\")\nbin_actual_means = df_base.groupby(\"bin\")[\"actual\"].mean()\n\nplt.figure(figsize=(7, 5))\n\n# Zero reference line\nplt.axhline(0, linestyle=\"--\", linewidth=2, color=\"black\", label=\"Perfect prediction\")\n\nfor name, y_pred in preds.items():\n    df_tmp = df_base.copy()\n    df_tmp[\"residual\"] = y_pred - y_true\n    bin_residual_means = df_tmp.groupby(\"bin\")[\"residual\"].mean()\n\n    if name == \"CatBoost\":\n        plt.plot(\n            bin_actual_means,\n            bin_residual_means,\n            marker=\"o\",\n            linewidth=3,\n            label=name\n        )\n    else:\n        plt.plot(\n            bin_actual_means,\n            bin_residual_means,\n            marker=\"o\",\n            linewidth=1.5,\n            alpha=0.7,\n            label=name\n        )\n\nplt.xlabel(\"Average Actual Energy Consumption (per bin)\")\nplt.ylabel(\"Average Prediction Error (Predicted − Actual)\")\nplt.title(\"OOF Bias by Consumption Level (6 bins)\")\nplt.legend()\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:33:34.684962Z","iopub.execute_input":"2026-02-10T20:33:34.685934Z","iopub.status.idle":"2026-02-10T20:33:35.005611Z","shell.execute_reply.started":"2026-02-10T20:33:34.685899Z","shell.execute_reply":"2026-02-10T20:33:35.004673Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 3.3 Advanced Ensemble: Ridge Blender\n\nAfter training our four base models, we needed a way to combine them that was smarter than just guessing weights (like 0.4 * CatBoost + 0.3 * XGBoost). This is where the Blender comes in.\n\nInstead of manually assigning importance to each model, we trained a second-level model (a Meta-Learner) to make the decision for us. We treated the predictions from our base models (CatBoost, XGBoost, Ridge, Random Forest) as new features and the actual energy consumption as the target. \n\nEssentially, we trained a model on the outputs of other models.\n\nWe used Ridge Regression for this final combining step for three specific reasons:\n\n**Automatic Weighting:** It mathematically calculates the optimal contribution of each model. If the Random Forest model is consistently wrong in a specific way, Ridge will learn to down-weight it automatically.\n\n*Correction:** Unlike a simple average, Ridge can theoretically assign negative weights. This allows it to use one model to \"subtract\" the systematic error of another.\n\n**Safety:** The regularization in Ridge prevents it from overfitting to the OOF predictions. A more complex blender (like another Gradient Boosting model) might just memorize the training data's noise, but Ridge keeps the final combination simple and robust.\n\n","metadata":{}},{"cell_type":"code","source":"from sklearn.linear_model import Ridge as BlendRidge\n\n# Stack OOF predictions (each column = one model's predictions)\nS_oof = np.column_stack([oof_cb, oof_xgb, oof_ridge, oof_rf])\nS_test = np.column_stack([test_cb, test_xgb, test_ridge, test_rf])\n\n# Train blender on OOF predictions\nblender = BlendRidge(alpha=1.0, fit_intercept=True, random_state=RANDOM_STATE)\nblender.fit(S_oof, y_train)\n\n# Extract learned weights\nw_cb_b, w_xgb_b, w_ridge_b, w_rf_b = blender.coef_\nb0 = blender.intercept_\n\nprint(\"\\n\" + \"=\"*80)\nprint(\"RIDGE BLENDER: Learned Weights\")\nprint(\"=\"*80)\nprint(f\"Intercept: {b0:.6f}\")\nprint(f\"\\nWeights:\")\nprint(f\"  CatBoost:      {w_cb_b:+.4f}\")\nprint(f\"  XGBoost:       {w_xgb_b:+.4f}\")\nprint(f\"  Ridge:         {w_ridge_b:+.4f}\")\nprint(f\"  Random Forest: {w_rf_b:+.4f}\")\n\n# Calculate blended predictions\noof_blend = blender.predict(S_oof)\ntest_blend = blender.predict(S_test)\n\nblend_rmse = rmse_score(y_train, oof_blend)\nprint(f\"\\nBlender OOF RMSE: {blend_rmse:.4f} kWh\")\nprint(\"=\"*80)\n\nprint(\"\\n Interpretation:\")\nprint(\"  • Positive weights: Model contributes positively to ensemble\")\nprint(\"  • Negative weights: Model predictions are subtracted (noisy/redundant)\")\nprint(\"  • Magnitude: Importance of model in final blend\")\n\nif w_ridge_b < 0 or w_rf_b < 0:\n    print(\"\\n  Negative weights detected!\")\n    print(\"    Ridge and/or RF may be redundant given CatBoost + XGBoost\")\n    print(\"    Consider a simpler 2-model ensemble\")\n\n# Save blended submission\nsubmission_blend = pd.DataFrame({\n    'id': test['id'],\n    'energy_consumption': np.clip(test_blend, 0, None)\n})\nsubmission_blend.to_csv('submission_blender.csv', index=False)\nprint(\"\\n Saved submission_blender.csv\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:33:43.015114Z","iopub.execute_input":"2026-02-10T20:33:43.016189Z","iopub.status.idle":"2026-02-10T20:33:43.063742Z","shell.execute_reply.started":"2026-02-10T20:33:43.016155Z","shell.execute_reply":"2026-02-10T20:33:43.062583Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 3.3 Simplified Ensemble: CatBoost + XGBoost Only\n\nAfter analyzing the initial weights assigned by our Ridge blender, we observed a potential issue: the linear Ridge model and the Random Forest model were receiving negligible or even negative weights. This signaled that they were not contributing unique information to the prediction.\n\n#### Rationale for Pruning\n\nWe hypothesized that including these weaker models was detrimental for three reasons:\n\n**Redundancy:** The gradient boosting models (CatBoost and XGBoost) are powerful enough to capture both the complex non-linear patterns found by Random Forest and the simpler trends found by Ridge. The weaker models were essentially telling the blender what it already knew.\n\n**Noise Injection:** Every model has an error term. By adding models that aren't improving the signal, we are just adding their specific error variance to our final output.\n\n**Overfitting Risk:** A blender with too many inputs can start \"memorizing\" which model is best for which specific training point, rather than learning general rules.\n\n#### The Simplified Strategy\n\nTo test this hypothesis, we stripped the ensemble down to its two strongest components: **CatBoost + XGBoost**.\n\n- **CatBoost** handles the categorical data and interactions.  \n- **XGBoost** provides a slightly different mathematical approach to the gradient descent.\n\nBy averaging only these two \"A-students,\" we aimed to create a cleaner, more robust signal that generalizes better to unseen data.","metadata":{}},{"cell_type":"code","source":"# 2-model blend (CatBoost + XGBoost)\nS_oof_2 = np.column_stack([oof_cb, oof_xgb])\nS_test_2 = np.column_stack([test_cb, test_xgb])\n\nblender_2 = BlendRidge(alpha=1.0, fit_intercept=True, random_state=RANDOM_STATE)\nblender_2.fit(S_oof_2, y_train)\n\nw_cb_2, w_xgb_2 = blender_2.coef_\nb0_2 = blender_2.intercept_\n\nprint(\"\\n\" + \"=\"*80)\nprint(\"2-MODEL BLENDER: CatBoost + XGBoost\")\nprint(\"=\"*80)\nprint(f\"Intercept: {b0_2:.6f}\")\nprint(f\"\\nWeights:\")\nprint(f\"  CatBoost: {w_cb_2:+.4f}\")\nprint(f\"  XGBoost:  {w_xgb_2:+.4f}\")\n\noof_blend_2 = blender_2.predict(S_oof_2)\ntest_preds_2 = np.clip(blender_2.predict(S_test_2), 0, None)\n\nblend_2_rmse = rmse_score(y_train, oof_blend_2)\nprint(f\"\\n2-model Blender OOF RMSE: {blend_2_rmse:.4f} kWh\")\nprint(\"=\"*80)\n\n# Save 2-model submission\npd.DataFrame({\n    'id': test['id'],\n    'energy_consumption': test_preds_2\n}).to_csv('submission_blender_cb_xgb.csv', index=False)\n\nprint(\"\\n Saved submission_blender_cb_xgb.csv\")\n\n# Compare all approaches\nprint(\"\\n\" + \"=\"*80)\nprint(\"ENSEMBLE COMPARISON\")\nprint(\"=\"*80)\nprint(f\"Manual weights (4 models): {rmse_score(y_train, oof_ensemble):.4f} kWh\")\nprint(f\"Ridge blender (4 models):  {blend_rmse:.4f} kWh\")\nprint(f\"Ridge blender (2 models):  {blend_2_rmse:.4f} kWh\")\nprint(f\"CatBoost alone:            {rmse_score(y_train, oof_cb):.4f} kWh\")\nprint(\"=\"*80)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-02-10T20:33:53.246963Z","iopub.execute_input":"2026-02-10T20:33:53.247443Z","iopub.status.idle":"2026-02-10T20:33:53.287709Z","shell.execute_reply.started":"2026-02-10T20:33:53.247415Z","shell.execute_reply":"2026-02-10T20:33:53.286714Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 3.4 Final Model Selection\n\nAfter evaluating both the single-model performances and the ensemble results, we faced a critical decision: should we submit the complex blended model or the best individual model?\n\nWe evaluated our options based on three factors:\n\n1. **OOF Performance:** The primary metric. The model with the lowest Root Mean Squared Error (RMSE) on the cross-validation data is statistically most likely to perform well on the test set.\n\n2. **Structural Risk (Occam's Razor):** If two models have similar performance, the simpler one is preferred. A complex ensemble with many moving parts has more \"degrees of freedom,\" meaning more ways it can accidentally memorize noise in the training data.\n\n3. **Robustness:** How likely is the model to fail if the test data has a slightly different distribution (e.g., a colder wintee than the training set)?\n\nContrary to the common expectation that \"ensembles are always better,\" our results showed that the **Single CatBoost Model** actually outperformed the **Ensemble**.\n\nThis phenomenon suggests that the other models (Ridge, Random Forest) were not just \"weaker\"- they were introducing noise. By averaging a highly accurate model with less accurate ones, we were effectively diluting the quality of our predictions. Furthermore, the single CatBoost model is far less likely to overfit than a two-layer stacking architecture.\n\n\n **Key insight:** More complex ≠ better!","metadata":{}},{"cell_type":"markdown","source":"---\n## Part 4: Explainable AI (XAI) Analysis\n---\n\nIn this stage of the analysis, explainable artificial intelligence techniques (XAI) are used to improve the understanding of how the models make predictions. The goal is to explain why certain predictions occur and which features have the greatest impact on building enery consumption. \n\nThe XAI methods applied are the following: \n- **Feature Importance:** Global measures derived from multiple predictors to identify the most influential predictors.\n- **Permutation Importance:** A model-agnostic technique that measures how model performance changes when a feature is randomly shuffled.\n- **Partial Dependence Plots:** Visualizations showing the average effect of a feature on the predicted outcome.\n- **SHAP Values:** Local and global explanations that show both the size and direction of each feature’s influence. Feature Interactions: Exploration of how pairs of features work together and affect predictions.","metadata":{}},{"cell_type":"markdown","source":"### 4.1 Feature Importance Analysis\n\nFeature importance will be computed to quantify how much each input variable contributes to the model’s predictions and to identify the most influential factors for building energy consumption.\n\n**Model-Specific Feature Importance:** Derived from tree-based models based on how features are used for data splitting.The method is fast to compute, but results may be affected by feature scale and correlation.\n","metadata":{}},{"cell_type":"code","source":"# We'll analyze the first fold's models for XAI\nmodel_cb_xai = models_cb[0]\nmodel_xgb_xai = models_xgb[0]\nmodel_rf_xai = models_rf[0]\n\n# Get feature names from the first fold's training data\n# We need to reconstruct it to get the exact feature names\nkf_xai = KFold(n_splits=N_SPLITS, shuffle=True, random_state=RANDOM_STATE)\ntr_idx_xai, _ = list(kf_xai.split(X_train))[0]\n\nX_tr_xai = X_train.iloc[tr_idx_xai].copy()\nimputer_xai = SimpleImputer(strategy='median')\nX_tr_xai[num_cols] = imputer_xai.fit_transform(X_tr_xai[num_cols])\nX_tr_xai = pd.get_dummies(X_tr_xai, columns=['heating_type'], prefix='heat')\nX_tr_xai_numeric = X_tr_xai.drop(columns=['insulation', 'id'], errors='ignore')\n\nfeature_names = X_tr_xai_numeric.columns.tolist()\nprint(f\"Total features: {len(feature_names)}\")\nprint(f\"\\nFeature names:\")\nfor i, f in enumerate(feature_names, 1):\n    print(f\"  {i:2d}. {f}\")\n    if i >= 15:\n        print(f\"  ... and {len(feature_names) - 15} more\")\n        break","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Extract feature importance from each model\ncb_importance = pd.DataFrame({\n    'feature': feature_names,\n    'importance': model_cb_xai.feature_importances_\n}).sort_values('importance', ascending=False)\n\nxgb_importance = pd.DataFrame({\n    'feature': feature_names,\n    'importance': model_xgb_xai.feature_importances_\n}).sort_values('importance', ascending=False)\n\nrf_importance = pd.DataFrame({\n    'feature': feature_names,\n    'importance': model_rf_xai.feature_importances_\n}).sort_values('importance', ascending=False)\n\n# Visualize top features from each model\nfig, axes = plt.subplots(1, 3, figsize=(18, 6))\n\n# CatBoost\naxes[0].barh(cb_importance.head(12)['feature'], cb_importance.head(12)['importance'], color='steelblue')\naxes[0].set_xlabel('Importance', fontsize=11)\naxes[0].set_title('CatBoost: Top 12 Features', fontsize=13, fontweight='bold')\naxes[0].invert_yaxis()\naxes[0].tick_params(axis='y', labelsize=9)\n\n# XGBoost\naxes[1].barh(xgb_importance.head(12)['feature'], xgb_importance.head(12)['importance'], color='coral')\naxes[1].set_xlabel('Importance', fontsize=11)\naxes[1].set_title('XGBoost: Top 12 Features', fontsize=13, fontweight='bold')\naxes[1].invert_yaxis()\naxes[1].tick_params(axis='y', labelsize=9)\n\n# Random Forest\naxes[2].barh(rf_importance.head(12)['feature'], rf_importance.head(12)['importance'], color='forestgreen')\naxes[2].set_xlabel('Importance', fontsize=11)\naxes[2].set_title('Random Forest: Top 12 Features', fontsize=13, fontweight='bold')\naxes[2].invert_yaxis()\naxes[2].tick_params(axis='y', labelsize=9)\n\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n Top 10 Most Important Features (CatBoost):\")\nprint(cb_importance.head(10).to_string(index=False))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 4.2 Permutation Importance (Model-Agnostic)\n\nPermutation importance is used to assess the impact of each input feature on the model’s predictive performance by analyzing how performance changes when feature values are randomly permuted.\n\n**Procedure:**\nBaseline model performance is first computed on the validation set. The values of one feature at a time are then randomly shuffled, breaking the relationship between that feature and the target variable. The resulting increase in RMSE is measured, and this procedure is repeated for all features.\n\n**Interpretation:**\nA large increase in RMSE indicates that the feature is important, as the model relies heavily on it. A small change in RMSE suggests that the feature has a limited influence on predictions. This method is generally more reliable than built-in feature importance when features are correlated.","metadata":{}},{"cell_type":"code","source":"# Calculate permutation importance for CatBoost\n# Use a sample for computational efficiency\nsample_size = min(1500, len(X_tr_xai_numeric))\nsample_idx = np.random.choice(len(X_tr_xai_numeric), sample_size, replace=False)\nX_sample = X_tr_xai_numeric.iloc[sample_idx]\ny_sample = y_train[tr_idx_xai][sample_idx]\n\nprint(\"Calculating permutation importance (this may take a minute)...\\n\")\nperm_importance = permutation_importance(\n    model_cb_xai,\n    X_sample,\n    y_sample,\n    n_repeats=10,\n    random_state=RANDOM_STATE,\n    n_jobs=-1,\n    scoring='neg_root_mean_squared_error'\n)\n\n# Create DataFrame\nperm_imp_df = pd.DataFrame({\n    'feature': feature_names,\n    'importance_mean': perm_importance.importances_mean,\n    'importance_std': perm_importance.importances_std\n}).sort_values('importance_mean', ascending=False)\n\n# Plot\nplt.figure(figsize=(10, 8))\ntop_n = 15\nplt.barh(\n    perm_imp_df.head(top_n)['feature'],\n    perm_imp_df.head(top_n)['importance_mean'],\n    xerr=perm_imp_df.head(top_n)['importance_std'],\n    color='purple',\n    alpha=0.7\n)\nplt.xlabel('Increase in RMSE when feature is shuffled (kWh)', fontsize=11)\nplt.title('Permutation Importance: CatBoost Model', fontsize=13, fontweight='bold')\nplt.gca().invert_yaxis()\nplt.tick_params(axis='y', labelsize=9)\nplt.grid(axis='x', alpha=0.3)\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n Permutation Importance - Top 10 Features:\")\nprint(perm_imp_df.head(10).to_string(index=False))\nprint(\"\\n Interpretation:\")\nprint(\"   • Higher values = bigger RMSE increase when feature is randomized\")\nprint(\"   • These features are most critical for accurate predictions\")\nprint(\"   • Features with high std may have interaction effects\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 4.3 Partial Dependence Plots (PDPs)\n\nPartial Dependence Plots show the average effect of a single feature on model predictions while holding other features constant.\n\n**Interpretation:**\nThe x-axis represents feature values and the y-axis shows predicted energy consumption. An upward trend indicates a positive relationship, a downward trend indicates a negative relationship, a flat line suggests little influence, and non-linear shapes indicate more complex effects.\n\n**Limitations:**\nPDPs assume feature independence and may be misleading when strong correlations exist.","metadata":{}},{"cell_type":"code","source":"# Select top features for PDP analysis\ntop_pdp_features = cb_importance.head(6)['feature'].tolist()\n\nprint(f\"Creating Partial Dependence Plots for top {len(top_pdp_features)} features...\\n\")\nprint(\"Features analyzed:\")\nfor i, f in enumerate(top_pdp_features, 1):\n    print(f\"  {i}. {f}\")\n\n# Create PDPs\nfig, axes = plt.subplots(2, 3, figsize=(18, 10))\naxes = axes.ravel()\n\nfor i, feature in enumerate(top_pdp_features):\n    feature_idx = feature_names.index(feature)\n    \n    # Calculate partial dependence\n    pd_result = partial_dependence(\n        model_cb_xai,\n        X_sample,\n        features=[feature_idx],\n        grid_resolution=50\n    )\n    \n    # Plot\n    axes[i].plot(pd_result['grid_values'][0], pd_result['average'][0], \n                 linewidth=2.5, color='darkblue')\n    axes[i].set_xlabel(feature, fontsize=11, fontweight='bold')\n    axes[i].set_ylabel('Predicted Energy (kWh)', fontsize=11)\n    axes[i].set_title(f'PDP: {feature}', fontsize=12, fontweight='bold')\n    axes[i].grid(alpha=0.3)\n\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n How to interpret PDPs:\")\nprint(\"   • Upward trend = feature increases → energy consumption increases\")\nprint(\"   • Downward trend = feature increases → energy consumption decreases\")\nprint(\"   • Flat line = feature has little marginal effect\")\nprint(\"   • Non-linear curves = complex relationships (e.g., U-shaped for temp)\")\nprint(\"   • Steep slope = strong effect magnitude\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"\n### 4.4 SHAP (SHapley Additive exPlanations)\n\n\nSHAP (SHapley Additive exPlanations) is a method used to explain model predictions by assigning a contribution value to each input feature. The method is based on ideas from game theory and aims to fairly distribute the impact of all features on a prediction.\n\n**Advantages:**\nSHAP provides a solid and consistent way to interpret model behavior. It works across different types of models and allows explanations at both the individual prediction level and the overall model level by aggregating results.\n\n**SHAP Values explained:**\n```\nprediction = base_value + sum(SHAP values for all features)\n```\n- **Positive SHAP**: Feature pushes prediction higher\n- **Negative SHAP**: Feature pushes prediction lower\n- **Magnitude**: How much the feature contributes\n\n**Example:**\n```\nBase prediction: 20 kWh (average across all buildings)\n  + occupancy SHAP: +5.2 kWh (high occupancy)\n  + temp_outdoor SHAP: +3.1 kWh (hot day → AC use)\n  - insulation_score SHAP: -2.5 kWh (good insulation)\n  + other features: -0.8 kWh\n  = Final prediction: 25.0 kWh\n```","metadata":{}},{"cell_type":"code","source":"# Initialize SHAP explainer for CatBoost\nprint(\"Initializing SHAP explainer (this may take a moment)...\\n\")\n\n# Use a sample for faster computation\nshap_sample_size = min(800, len(X_tr_xai_numeric))\nshap_sample_idx = np.random.choice(len(X_tr_xai_numeric), shap_sample_size, replace=False)\nX_shap = X_tr_xai_numeric.iloc[shap_sample_idx]\n\n# Create SHAP explainer\nexplainer = shap.TreeExplainer(model_cb_xai)\nshap_values = explainer.shap_values(X_shap)\n\nprint(f\"✓ SHAP values calculated for {shap_sample_size} samples\")\nprint(f\"✓ Base value (average prediction): {explainer.expected_value:.2f} kWh\\n\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"#### 4.4.1 SHAP Summary Plot (Global Importance)\n\n**Elements:**\n- **Y-axis**: Features (sorted by importance)\n- **X-axis**: SHAP value (impact on prediction in kWh)\n- **Color**: Feature value (red = high, blue = low)\n- **Each dot**: One prediction instance\n\n**Interpretation:**\n- Features at top = most important globally\n- Spread on x-axis = impact magnitude\n- **Color patterns reveal relationships**:\n  - Red dots on right = high feature value → increases prediction\n  - Blue dots on left = low feature value → decreases prediction\n  - Vertical spread = feature interactions (effect varies by context)","metadata":{}},{"cell_type":"code","source":"# SHAP Summary Plot\nplt.figure(figsize=(10, 10))\nshap.summary_plot(shap_values, X_shap, plot_type=\"dot\", show=False, max_display=20)\nplt.title('SHAP Summary Plot: Feature Impact on Energy Predictions', \n          fontsize=14, fontweight='bold', pad=20)\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n Reading the SHAP Summary Plot:\")\nprint(\"   • Features at the top are most important globally\")\nprint(\"   • Red dots = high feature values\")\nprint(\"   • Blue dots = low feature values\")\nprint(\"   • Position on x-axis shows impact direction:\")\nprint(\"     - Right (positive) = increases energy consumption\")\nprint(\"     - Left (negative) = decreases energy consumption\")\nprint(\"   • Vertical spread indicates interaction effects\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"#### 4.4.2 SHAP Bar Plot (Mean Absolute Impact)\n\nThis plot displays the average absolute contribution of each feature to the model’s predictions. It provides a simplified view compared to the SHAP summary plot and helps answer how much each feature matters on average. The plot shows only the magnitude of feature impact and does not indicate whether the effect is positive or negative.","metadata":{}},{"cell_type":"code","source":"# SHAP Bar Plot (mean absolute SHAP values)\nplt.figure(figsize=(10, 10))\nshap.summary_plot(shap_values, X_shap, plot_type=\"bar\", show=False, max_display=20)\nplt.title('SHAP Bar Plot: Mean Absolute Impact on Predictions', \n          fontsize=14, fontweight='bold', pad=20)\nplt.xlabel('Mean |SHAP value| (average impact on model output in kWh)', fontsize=11)\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n Reading the SHAP Bar Plot:\")\nprint(\"   • Longer bars = more important features\")\nprint(\"   • Values represent average absolute contribution\")\nprint(\"   • Compare with permutation importance for validation\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"#### 4.4.3 SHAP Dependence Plots (Feature Relationships)\n\nSHAP dependence plots show how feature values relate to their contribution to model predictions and highlight interaction effects with other features using color.\n\n**Advantages over PDPs:** These plots display individual data points rather than averages, making interactions easier to detect and results more reliable for correlated features. They also reveal variation in feature effects across observations.\n\n**Reading the plot:** The x-axis represents the feature value and the y-axis shows the SHAP value. Color indicates an interacting feature. A wide vertical spread suggests interactions, while a clear trend indicates a direct relationship.","metadata":{}},{"cell_type":"code","source":"# SHAP Dependence Plots for top features\ntop_shap_features = cb_importance.head(6)['feature'].tolist()\n\nprint(\"Creating SHAP dependence plots...\\n\")\n\nfig, axes = plt.subplots(2, 3, figsize=(18, 12))\naxes = axes.ravel()\n\nfor i, feature in enumerate(top_shap_features):\n    plt.sca(axes[i])\n    shap.dependence_plot(\n        feature,\n        shap_values,\n        X_shap,\n        interaction_index=\"auto\",  # Automatically find best interaction\n        show=False,\n        ax=axes[i]\n    )\n    axes[i].set_title(f'SHAP Dependence: {feature}', fontsize=12, fontweight='bold')\n\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n Reading SHAP Dependence Plots:\")\nprint(\"   • X-axis: Feature value\")\nprint(\"   • Y-axis: SHAP value (contribution to prediction)\")\nprint(\"   • Color: Interaction with another important feature\")\nprint(\"   • Vertical spread = feature interactions matter\")\nprint(\"   • Clear trend = direct relationship\")\nprint(\"   • Horizontal band = feature has consistent effect\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"#### 4.4.4 Individual Prediction Explanation (Waterfall Plot)\n\nThe SHAP waterfall plot explains how a single building’s prediction is constructed by showing how each feature contributes to moving the prediction away from the average (base) value toward the final predicted energy consumption.\n\n**Use case:**\nThis visualization is particularly useful for communicating results to stakeholders, as it clearly shows which factors increase or decrease the predicted energy use for an individual building.\n\n**Reading the plot:**\nThe base value (average prediction) appears at the bottom of the plot. Each bar represents a feature’s contribution, with red bars increasing and blue bars decreasing the prediction. The final prediction is shown at the top.","metadata":{}},{"cell_type":"code","source":"# Select an interesting sample to explain\nsample_idx_explain = 0\nsample_prediction = model_cb_xai.predict(X_shap.iloc[[sample_idx_explain]])[0]\nsample_actual = y_train[tr_idx_xai][shap_sample_idx[sample_idx_explain]]\n\nprint(f\"Explaining prediction for sample #{sample_idx_explain}\")\nprint(f\"Predicted energy consumption: {sample_prediction:.2f} kWh\")\nprint(f\"Actual energy consumption: {sample_actual:.2f} kWh\")\nprint(f\"Prediction error: {abs(sample_prediction - sample_actual):.2f} kWh\\n\")\n\n# Show feature values for this sample\nprint(\"Sample feature values:\")\nfor feat, val in X_shap.iloc[sample_idx_explain].items():\n    if abs(shap_values[sample_idx_explain][list(feature_names).index(feat)]) > 0.5:\n        print(f\"  {feat}: {val:.2f}\")\n\n# Create waterfall plot\nshap.initjs()\nshap_explanation = shap.Explanation(\n    values=shap_values[sample_idx_explain],\n    base_values=explainer.expected_value,\n    data=X_shap.iloc[sample_idx_explain],\n    feature_names=feature_names\n)\n\nplt.figure(figsize=(12, 8))\nshap.waterfall_plot(shap_explanation, show=False, max_display=15)\nplt.title(f'SHAP Waterfall: Building Prediction Breakdown', fontsize=13, fontweight='bold')\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n Reading the Waterfall Plot:\")\nprint(\"   • Start at E[f(X)]: Average prediction across all buildings\")\nprint(\"   • Each bar shows one feature's contribution\")\nprint(\"   • Red/Pink: Feature increases prediction\")\nprint(\"   • Blue: Feature decreases prediction\")\nprint(\"   • End at f(x): Final prediction for this specific building\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"#### 4.4.5 SHAP Force Plot (Alternative View)\n\nThe SHAP force plot provides an alternative visualization of an individual prediction, presenting the same information as the waterfall plot in a different format.\n\n**Interpretation:**\nFeatures are shown as forces that push the prediction higher (red) or lower (blue). The width of each segment represents the magnitude of the feature’s contribution.","metadata":{}},{"cell_type":"code","source":"# Force plot for individual prediction\nshap.initjs()\nplt.figure(figsize=(16, 3))\nshap.force_plot(\n    explainer.expected_value,\n    shap_values[sample_idx_explain],\n    X_shap.iloc[sample_idx_explain],\n    matplotlib=True,\n    show=False\n)\nplt.title(f'SHAP Force Plot: Individual Prediction Forces', \n          fontsize=13, fontweight='bold', pad=20)\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n Reading the Force Plot:\")\nprint(\"   • Base value (center): Average prediction\")\nprint(\"   • Red: Features pushing prediction higher\")\nprint(\"   • Blue: Features pushing prediction lower\")\nprint(\"   • Width: Size of contribution\")\nprint(\"   • Output value: Final prediction\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 4.5 Feature Interaction Analysis\n\nFeature interactions occur when the effect of one feature on the prediction depends on the value of another feature. Analyzing these interactions helps capture combined effects beyond individual feature contributions.\n\nFor example, insulation quality may have a stronger impact under extreme temperatures, window age may matter more at high solar irradiance, and the effect of occupancy may vary with floor area.\n\n**SHAP Interaction Values:**\nSHAP interaction values quantify these effects, with diagonal terms representing main effects and off-diagonal terms representing pairwise interactions. The interaction matrix is symmetric.","metadata":{}},{"cell_type":"code","source":"# Calculate SHAP interaction values (computationally expensive)\ninteraction_sample_size = min(150, len(X_shap))\nX_interaction = X_shap.iloc[:interaction_sample_size]\n\nprint(f\"Calculating SHAP interaction values for {interaction_sample_size} samples...\")\nprint(\"(This may take 1-2 minutes)\\n\")\n\nshap_interaction_values = explainer.shap_interaction_values(X_interaction)\n\n# Select top features for interaction heatmap\ntop_n_interact = 10\ntop_indices = [feature_names.index(f) for f in cb_importance.head(top_n_interact)['feature']]\n\n# Calculate mean absolute interaction values\nmean_abs_interactions = np.abs(shap_interaction_values).mean(0)\n\n# Create interaction matrix for top features\ninteraction_matrix = mean_abs_interactions[np.ix_(top_indices, top_indices)]\ntop_feature_names = [feature_names[i] for i in top_indices]\n\n# Plot heatmap\nplt.figure(figsize=(12, 10))\nsns.heatmap(\n    interaction_matrix,\n    xticklabels=top_feature_names,\n    yticklabels=top_feature_names,\n    annot=True,\n    fmt='.3f',\n    cmap='YlOrRd',\n    cbar_kws={'label': 'Mean |SHAP interaction| (kWh)'},\n    square=True\n)\nplt.title('SHAP Interaction Heatmap: Feature Pair Effects', \n          fontsize=14, fontweight='bold', pad=15)\nplt.xticks(rotation=45, ha='right', fontsize=9)\nplt.yticks(rotation=0, fontsize=9)\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n Reading the Interaction Heatmap:\")\nprint(\"   • Diagonal: Main effects of individual features\")\nprint(\"   • Off-diagonal: Interaction effects between feature pairs\")\nprint(\"   • Darker/warmer colors: Stronger interaction\")\nprint(\"   • Symmetric matrix: interaction(A,B) = interaction(B,A)\")\nprint(\"\\nStrong interactions suggest:\")\nprint(\"   - Features work together to influence predictions\")\nprint(\"   - Effect of one feature depends on value of another\")\nprint(\"   - May want to create explicit interaction features\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 4.6 Model Comparison: Feature Importance Consensus\n\nFeature importance results from multiple explainability methods are compared to identify a consensus among the most influential predictors. Features that consistently rank high across different methods are considered more reliable.\n\n**Interpretation:**\nDifferences between methods may indicate the presence of feature correlations, non-linear effects, or interaction effects, which can influence how importance is estimated by tree-based measures, permutation importance, and SHAP, respectively.","metadata":{}},{"cell_type":"code","source":"# Create comparison dataframe\ncomparison_df = pd.DataFrame({\n    'feature': feature_names\n})\n\n# Add importance from each method\ncomparison_df = comparison_df.merge(\n    cb_importance.set_index('feature')[['importance']].rename(columns={'importance': 'CatBoost'}),\n    left_on='feature', right_index=True\n)\ncomparison_df = comparison_df.merge(\n    xgb_importance.set_index('feature')[['importance']].rename(columns={'importance': 'XGBoost'}),\n    left_on='feature', right_index=True\n)\ncomparison_df = comparison_df.merge(\n    rf_importance.set_index('feature')[['importance']].rename(columns={'importance': 'RandomForest'}),\n    left_on='feature', right_index=True\n)\ncomparison_df = comparison_df.merge(\n    perm_imp_df.set_index('feature')[['importance_mean']].rename(columns={'importance_mean': 'Permutation'}),\n    left_on='feature', right_index=True\n)\n\n# Normalize to 0-1 scale for fair comparison\nfor col in ['CatBoost', 'XGBoost', 'RandomForest', 'Permutation']:\n    col_min = comparison_df[col].min()\n    col_max = comparison_df[col].max()\n    comparison_df[col] = (comparison_df[col] - col_min) / (col_max - col_min)\n\n# Calculate average importance across methods\ncomparison_df['Average'] = comparison_df[['CatBoost', 'XGBoost', 'RandomForest', 'Permutation']].mean(axis=1)\ncomparison_df = comparison_df.sort_values('Average', ascending=False)\n\n# Plot comparison for top features\ntop_n_compare = 15\nfig, ax = plt.subplots(figsize=(14, 8))\n\nx = np.arange(top_n_compare)\nwidth = 0.2\n\nax.bar(x - 1.5*width, comparison_df.head(top_n_compare)['CatBoost'], \n       width, label='CatBoost', alpha=0.8, color='steelblue')\nax.bar(x - 0.5*width, comparison_df.head(top_n_compare)['XGBoost'], \n       width, label='XGBoost', alpha=0.8, color='coral')\nax.bar(x + 0.5*width, comparison_df.head(top_n_compare)['RandomForest'], \n       width, label='RandomForest', alpha=0.8, color='forestgreen')\nax.bar(x + 1.5*width, comparison_df.head(top_n_compare)['Permutation'], \n       width, label='Permutation', alpha=0.8, color='purple')\n\nax.set_xlabel('Features', fontsize=12, fontweight='bold')\nax.set_ylabel('Normalized Importance', fontsize=12, fontweight='bold')\nax.set_title('Feature Importance Comparison Across Methods', fontsize=14, fontweight='bold')\nax.set_xticks(x)\nax.set_xticklabels(comparison_df.head(top_n_compare)['feature'], rotation=45, ha='right', fontsize=9)\nax.legend(loc='upper right', fontsize=10)\nax.grid(axis='y', alpha=0.3)\n\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n Top 15 Features by Average Importance:\")\nprint(comparison_df[['feature', 'Average']].head(15).to_string(index=False))\n\nprint(\"\\n Consensus Features:\")\nprint(\"   Features that rank high across multiple methods are most reliable.\")\nprint(\"   These should be the focus of:\")\nprint(\"     • Business decisions and interventions\")\nprint(\"     • Further feature engineering\")\nprint(\"     • Data collection priorities\")\nprint(\"     • Model monitoring in production\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"---\n## Part 5: Key Insights and Recommendations\n---","metadata":{}},{"cell_type":"code","source"